{
  "name": "qa-testcase-workflow",
  "version": "0.1.0",
  "displayName": "QA 测试用例工作流",
  "description": "测试工程师测试用例管理的完整工作流自动化，支持 PRD 分析、变更分析、用例生成、评审和归档",
  "author": {
    "name": "zengzhihua",
    "email": "1036181341@qq.com",
    "url": "https://github.com/run-noob"
  },
  "license": "MIT",
  "homepage": "https://github.com/run-noob/qa-testcase-workflow",
  "repository": {
    "type": "git",
    "url": "https://github.com/run-noob/qa-testcase-workflow.git"
  },
  "bugs": {
    "url": "https://github.com/run-noob/qa-testcase-workflow/issues"
  },
  "type": "workflow",
  "category": "Testing & Quality Assurance",
  "keywords": [
    "qa",
    "testing",
    "test-case",
    "test-management",
    "workflow",
    "automation",
    "prd-analysis",
    "测试用例",
    "测试管理",
    "自动化",
    "工作流"
  ],
  "mainSkill": "qa-workflow",
  "skills": [
    {
      "name": "qa-workflow",
      "path": "skills/qa-workflow",
      "description": "工作流总控，自动编排执行完整的5步测试用例管理流程",
      "primary": true,
      "version": "0.1.0",
      "commands": [
        "/qa-workflow"
      ],
      "aliases": [
        "workflow",
        "qa"
      ]
    },
    {
      "name": "qa-prd-analysis",
      "path": "skills/qa-prd-analysis",
      "description": "分析PRD文档，输出结构化需求分析报告、功能点、测试关注点与风险项",
      "version": "0.1.0",
      "commands": [
        "/qa-prd-analysis"
      ],
      "aliases": [
        "prd",
        "analysis"
      ]
    },
    {
      "name": "qa-change-diff",
      "path": "skills/qa-change-diff",
      "description": "分析需求变更对存量用例的影响，生成变更差异报告",
      "version": "0.1.0",
      "commands": [
        "/qa-change-diff"
      ],
      "aliases": [
        "diff",
        "change"
      ]
    },
    {
      "name": "qa-testcase-generation",
      "path": "skills/qa-testcase-generation",
      "description": "基于分析结果自动生成结构化测试用例",
      "version": "0.1.0",
      "commands": [
        "/qa-testcase-generation"
      ],
      "aliases": [
        "gen",
        "generate"
      ]
    },
    {
      "name": "qa-testcase-review",
      "path": "skills/qa-testcase-review",
      "description": "自动评审用例质量，识别问题并生成评审报告",
      "version": "0.1.0",
      "commands": [
        "/qa-testcase-review"
      ],
      "aliases": [
        "review"
      ]
    },
    {
      "name": "qa-testcase-merge",
      "path": "skills/qa-testcase-merge",
      "description": "将新用例合并到全量库，归档当前需求文档",
      "version": "0.1.0",
      "commands": [
        "/qa-testcase-merge"
      ],
      "aliases": [
        "merge"
      ]
    }
  ],
  "dependencies": {
    "runtime": {
      "minCodeBuddyVersion": "2.0.0",
      "platforms": [
        "win32",
        "darwin",
        "linux"
      ]
    },
    "directories": [
      {
        "path": "prd/current",
        "required": true,
        "autoCreate": true
      },
      {
        "path": "prd/archive",
        "required": true,
        "autoCreate": true
      },
      {
        "path": "test-cases",
        "required": true,
        "autoCreate": true
      },
      {
        "path": "glossary",
        "required": false,
        "autoCreate": true
      }
    ]
  },
  "features": [
    "一键执行完整的5步测试用例管理流程",
    "支持部分执行（--steps）、断点恢复（--resume）",
    "智能目录结构验证和自动创建",
    "实时进度可视化和状态追踪",
    "自动PRD分析和功能点提取",
    "存量用例变更影响分析",
    "基于模板的结构化用例生成",
    "自动化用例质量评审",
    "安全的用例合并和归档机制"
  ],
  "languages": [
    "zh-CN",
    "en"
  ],
  "documentation": {
    "readme": "README.md",
    "guide": "CLAUDE.md",
    "changelog": "CHANGELOG.md",
    "license": "LICENSE"
  },
  "assets": {
    "icon": ".codebuddy-plugin/icon.svg",
  },
  "config": {
    "defaults": {
      "autoCleanupState": true,
      "showProgress": true,
      "verboseLogging": false
    },
    "options": [
      {
        "name": "default_mode",
        "type": "string",
        "default": "auto",
        "enum": [
          "auto",
          "interactive"
        ],
        "description": "默认执行模式"
      },
      {
        "name": "review_strictness",
        "type": "string",
        "default": "normal",
        "enum": [
          "strict",
          "normal",
          "lenient"
        ],
        "description": "用例评审的严格程度"
      }
    ]
  },
  "permissions": [
    "filesystem:read",
    "filesystem:write",
    "filesystem:create",
    "filesystem:delete"
  ]
}